# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (the default) — SQLite. No database server, no keys.
# This is all you need to clone and run:  npm install && npm run setup && npm run dev
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"


# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT ON POSTGRES (Supabase / Neon / any Postgres) — see docs/DEPLOY.md
# Set these INSTEAD of the line above. Nothing else in the app changes.
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_PROVIDER="postgresql"
#
# The pooled connection, used by the running app.
# Supabase: Project Settings -> Database -> Connection string -> "Transaction pooler"
# DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# The DIRECT connection, used ONLY by `prisma migrate deploy`.
# pgbouncer in transaction mode cannot run DDL, so migrations must bypass the pooler.
# Supabase: the same page -> "Direct connection" (port 5432)
# DIRECT_DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# There are no other keys. Sessions are database rows, not signed tokens, so there is
# no JWT/session secret to configure. POD documents are stored in the database, so
# there is no object-storage credential either.
